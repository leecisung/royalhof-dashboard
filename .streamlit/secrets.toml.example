# Streamlit Community Cloud 배포 시 사용하는 secrets 템플릿.
# 실제 secrets.toml은 git에 절대 커밋 금지 (.gitignore에 포함됨).
# 배포 후 share.streamlit.io 의 App settings → Secrets 에 직접 붙여넣으면 됨.

# ─ 대시보드 비밀번호 (필수)
DASHBOARD_PASSWORD = "여기에-비밀번호"

# ─ 네이버 검색광고 (로얄호프 계정)
NAVER_AD_API_KEY = "..."
NAVER_AD_SECRET_KEY = "..."
NAVER_AD_CUSTOMER_ID = "..."

# ─ 네이버 검색광고 (버거리 신버 계정)
BURGEORI_NEW_API_KEY = "..."
BURGEORI_NEW_SECRET_KEY = "..."
BURGEORI_NEW_CUSTOMER_ID = "..."

# ─ 네이버 검색광고 (보승회관 계정)
BURGEORI_OLD_API_KEY = "..."
BURGEORI_OLD_SECRET_KEY = "..."
BURGEORI_OLD_CUSTOMER_ID = "..."

# ─ Meta Marketing API (버거리 FB 광고)
META_APP_ID = "..."
META_APP_SECRET = "..."
META_ACCESS_TOKEN = "..."
META_AD_ACCOUNT_ID = "act_..."
META_PIXEL_ID = "..."
META_PIXEL_EVENT = "COMPLETE_REGISTRATION"

# ─ GA4 (BigQuery 방식)
GA4_PROPERTY_ID = "534869930"
GA4_BQ_LOCATION = "asia-southeast3"
# Streamlit Cloud에는 파일 업로드가 안 되므로 GA4 BQ는 별도 처리 (배포 가이드 참조)

# ─ Anthropic Claude (AI 인사이트)
ANTHROPIC_API_KEY = "sk-ant-..."
