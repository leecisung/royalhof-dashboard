# =========================================================
# 네이버 검색광고 (로얄호프치킨)
# =========================================================
NAVER_AD_API_KEY=여기에_API키
NAVER_AD_SECRET_KEY=여기에_시크릿키
NAVER_AD_CUSTOMER_ID=여기에_고객ID

# ★ 기존 파워링크 캠페인 ID (쉼표 구분) — 이 캠페인은 절대 수정/삭제 안 함
# 네이버 광고관리시스템 → 캠페인 탭에서 캠페인 ID 확인 후 입력
# 예: PROTECTED_CAMPAIGN_IDS=cmp-00001-000001,cmp-00001-000002
PROTECTED_CAMPAIGN_IDS=

# =========================================================
# Meta Marketing API (FB/Instagram 광고 — 버거리)
# 발급 방법: docs/meta_setup_guide.md 참조
# =========================================================
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_           # 'act_' 프리픽스 포함
META_PAGE_ID=
META_PIXEL_ID=

# ★ 기존 Meta 캠페인 보호 (자동화 대상 LLA 캠페인은 여기 넣지 말 것)
META_PROTECTED_CAMPAIGN_IDS=

# 운영 룰 (기본값 유지 권장)
META_DAILY_BUDGET_TOTAL_KRW=80000
META_CPA_PAUSE_THRESHOLD=50000        # CPA 이 초과 시 ad set 일시정지
META_CPA_REDUCE_THRESHOLD=30000       # CPA 이 초과 + spend 5만+ → 예산 50% 삭감
META_CPA_BOOST_THRESHOLD=15000        # CPA 이 미만 + conv 5+ → 예산 30% 증액
META_FREQUENCY_FATIGUE=3.0            # frequency 이 초과 → 크리에이티브 fatigue 경고
META_BUDGET_CAP_PER_ADSET_KRW=50000   # ad set당 일 예산 상한
META_PIXEL_EVENT=Lead                  # 최적화 이벤트 (Lead/Purchase/ViewContent 등)
META_LEARNING_PROTECT_DAYS=14         # 생성 후 N일은 pause 룰 면제 (학습기간 보호)
META_LANDING_URL=https://burgerry.co.kr/

# =========================================================
# 공통 옵션
# =========================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...  # 옵션 — 주간보고 슬랙 전송
GA4_PROPERTY_ID=  # 옵션
